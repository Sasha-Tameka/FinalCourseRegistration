@page "{id:int}"
@model FinalCourseRegistration.Pages.Students.DeleteModel
@{
    ViewData["Title"] = "Delete Student";
}
<h2>Delete Student</h2>
<p>Are you sure you want to delete this student?</p>

<table border="1">
    <tr><th>First Name</th><td>@Model.Student.FirstName</td></tr>
    <tr><th>Last Name</th><td>@Model.Student.LastName</td></tr>
    <tr><th>Email</th><td>@Model.Student.Email</td></tr>
    <tr><th>Phone Number</th><td>@Model.Student.PhoneNumber</td></tr>
</table>

<form method="post">
    <input type="hidden" asp-for="Student.StudentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>