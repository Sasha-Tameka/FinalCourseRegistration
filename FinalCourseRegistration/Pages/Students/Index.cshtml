@page
@model FinalCourseRegistration.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}
<h2>Students</h2>

<p><a asp-page="Create" class="btn btn-primary">Add New Student</a></p>

<table border="1">
    <tr>
        <th>Student ID</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Phone Number</th>
        <th></th>
    </tr>
    @foreach (var student in Model.Students)
    {
        <tr>
            <td>@student.StudentId</td>
            <td>@student.FirstName</td>
            <td>@student.LastName</td>
            <td>@student.Email</td>
            <td>@student.PhoneNumber</td>
            <td>
                <a asp-page="Edit" asp-route-id="@student.StudentId">Edit</a> |
                <a asp-page="Delete" asp-route-id="@student.StudentId">Delete</a>
            </td>
        </tr>
    }
</table>