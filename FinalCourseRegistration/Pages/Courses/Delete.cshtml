@page "{id:int}"
@model FinalCourseRegistration.Pages.Courses.DeleteModel
@{
    ViewData["Title"] = "Delete Course";
}
<h2>Delete Course</h2>
<p>Are you sure you want to delete this course?</p>

<table border="1">
    <tr><th>Course Number</th><td>@Model.Course.CourseNumber</td></tr>
    <tr><th>Course Name</th><td>@Model.Course.CourseName</td></tr>
    <tr><th>Description</th><td>@Model.Course.Description</td></tr>
</table>

<form method="post">
    <input type="hidden" asp-for="Course.CourseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>